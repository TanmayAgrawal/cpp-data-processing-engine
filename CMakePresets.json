{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 27,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "debug",
      "displayName": "Debug",
      "generator": "Unix Makefiles",
      "binaryDir": "${sourceDir}/build/debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "DPE_BUILD_TESTS": "ON",
        "DPE_BUILD_BENCHMARKS": "OFF"
      }
    },
    {
      "name": "asan",
      "displayName": "ASan",
      "inherits": "debug",
      "binaryDir": "${sourceDir}/build/asan",
      "cacheVariables": {
        "DPE_ENABLE_ASAN": "ON",
        "DPE_ENABLE_UBSAN": "OFF",
        "DPE_BUILD_BENCHMARKS": "OFF"
      }
    },
    {
      "name": "ubsan",
      "displayName": "UBSan",
      "inherits": "debug",
      "binaryDir": "${sourceDir}/build/ubsan",
      "cacheVariables": {
        "DPE_ENABLE_ASAN": "OFF",
        "DPE_ENABLE_UBSAN": "ON",
        "DPE_BUILD_BENCHMARKS": "OFF"
      }
    },
    {
      "name": "release-bench",
      "displayName": "Release Bench",
      "generator": "Unix Makefiles",
      "binaryDir": "${sourceDir}/build/release-bench",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "DPE_BUILD_TESTS": "OFF",
        "DPE_BUILD_BENCHMARKS": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "build-debug",
      "configurePreset": "debug"
    },
    {
      "name": "build-asan",
      "configurePreset": "asan"
    },
    {
      "name": "build-ubsan",
      "configurePreset": "ubsan"
    },
    {
      "name": "build-release-bench",
      "configurePreset": "release-bench"
    }
  ],
  "testPresets": [
    {
      "name": "test-debug",
      "configurePreset": "debug",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "test-asan",
      "configurePreset": "asan",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "test-ubsan",
      "configurePreset": "ubsan",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}

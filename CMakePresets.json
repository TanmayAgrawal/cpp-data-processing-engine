{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 27,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "debug",
      "displayName": "Debug",
      "generator": "Unix Makefiles",
      "binaryDir": "${sourceDir}/build/debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "asan",
      "displayName": "ASan",
      "inherits": "debug",
      "binaryDir": "${sourceDir}/build/asan",
      "cacheVariables": {
        "DPE_ENABLE_ASAN": "ON",
        "DPE_ENABLE_UBSAN": "OFF"
      }
    },
    {
      "name": "ubsan",
      "displayName": "UBSan",
      "inherits": "debug",
      "binaryDir": "${sourceDir}/build/ubsan",
      "cacheVariables": {
        "DPE_ENABLE_ASAN": "OFF",
        "DPE_ENABLE_UBSAN": "ON"
      }
    },
    {
      "name": "release",
      "displayName": "Release",
      "generator": "Unix Makefiles",
      "binaryDir": "${sourceDir}/build/release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "build-debug",
      "configurePreset": "debug"
    },
    {
      "name": "build-asan",
      "configurePreset": "asan"
    },
    {
      "name": "build-ubsan",
      "configurePreset": "ubsan"
    },
    {
      "name": "build-release",
      "configurePreset": "release"
    }
  ]
}
